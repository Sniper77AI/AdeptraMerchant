# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
#
# NOTE: the with-supabase template names this var *_PUBLISHABLE_KEY, not
# *_ANON_KEY — it's the same anon/public key, just Supabase's current naming
# (see lib/supabase/client.ts / server.ts / proxy.ts, which all read this
# exact name). This is the anon key ONLY — never the service_role/secret key.
# RLS + the logged-in user's JWT is what scopes access; a service key in a
# browser-facing app would bypass RLS entirely.
NEXT_PUBLIC_SUPABASE_URL=https://qognnvjehcflbqlzxcru.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# --- Server-only (Stage 2: onboarding's analysis trigger) -------------------
# Deliberately NOT prefixed NEXT_PUBLIC_ — Next.js only inlines NEXT_PUBLIC_*
# vars into the client bundle, so these never reach the browser as long as
# they're only read inside Server Actions / Route Handlers. Same names as
# merchant/.env.example's SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY, kept as
# a SEPARATE pair here (not reused from NEXT_PUBLIC_SUPABASE_URL above) so
# the service-role code path can never accidentally get refactored to read a
# client-exposed var. This key bypasses RLS entirely — it runs the analysis
# pipeline (merchant/ucp/pipeline.ts's runAnalysis), which writes
# signals/pillar_scores/artifacts/analysis_runs, none of which grant INSERT/
# UPDATE to the authenticated role. NEVER import app/lib/onboarding-actions.ts
# (or anything that constructs this client) from a "use client" component.
SUPABASE_URL=https://qognnvjehcflbqlzxcru.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional — same LLM-degrades-to-not_applicable behavior as the merchant CLI.
OPENAI_API_KEY=your-openai-key-here
